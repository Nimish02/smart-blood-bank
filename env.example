# ─── Gmail SMTP ────────────────────────────────────────────────────────────────
# Your Gmail address used as the sender
GMAIL_SENDER=yourapp@gmail.com

# 16-character App Password (NOT your regular Gmail password)
# How to get one: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google Account
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Twilio WhatsApp (free sandbox) ────────────────────────────────────────────
# Sign up at: https://www.twilio.com/try-twilio
# Sandbox docs: https://www.twilio.com/docs/whatsapp/sandbox

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Default Twilio sandbox number — keep as-is for free tier
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Notes ─────────────────────────────────────────────────────────────────────
# • Free Twilio sandbox: recipients must first send "join <sandbox-keyword>"
#   to +1 415 523 8886 on WhatsApp before they can receive messages.
# • For production, upgrade to a paid Twilio account and use your own WA number.
# • Never commit this file to version control — add .env to your .gitignore!
